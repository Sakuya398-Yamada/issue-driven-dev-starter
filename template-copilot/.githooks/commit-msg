#!/usr/bin/env bash
# commit-msg hook.
# Rejects commits whose message violates the project convention:
#   <feat|fix|refactor|test|docs|chore|style>: <subject> #<issue>
#
# Issue number is required on regular branches but optional on
# `copilot/*` / `claude/*` session branches.
#
# Enable with: git config core.hooksPath .githooks
# Applies to every local commit — whether typed by a human or executed by an
# AI agent through the integrated terminal.

set -euo pipefail

msg_file="$1"
first_line=$(head -n 1 "$msg_file")

# Merge/revert commits generated by git itself are exempt.
case "$first_line" in
  Merge\ *|Revert\ *|fixup!\ *|squash!\ *)
    exit 0
    ;;
esac

current_branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")

issue_optional=0
case "$current_branch" in
  copilot/*|claude/*) issue_optional=1 ;;
esac

# Validate type prefix (always required)
if ! printf '%s' "$first_line" | grep -Eq '^(feat|fix|refactor|test|docs|chore|style): .+'; then
  cat >&2 <<EOF
[hook:commit-msg] Commit message violates the project convention.

  First line: $first_line
  Expected:   <feat|fix|refactor|test|docs|chore|style>: <subject> [#<issue>]
  Example:    feat: ユーザーデータモデルを追加 #1

  See .github/instructions/git-conventions.instructions.md for details.
EOF
  exit 1
fi

# Validate issue number (relaxed on session branches)
if [ "$issue_optional" -eq 0 ] && ! printf '%s' "$first_line" | grep -Eq '#[0-9]+'; then
  cat >&2 <<EOF
[hook:commit-msg] Commit message is missing the issue number.

  First line:     $first_line
  Current branch: $current_branch
  Expected:       <type>: <subject> #<issue>
  Example:        fix: 日付計算の境界条件を修正 #5

  Note: only branches matching 'copilot/*' or 'claude/*' may omit the issue number.
EOF
  exit 1
fi

exit 0
