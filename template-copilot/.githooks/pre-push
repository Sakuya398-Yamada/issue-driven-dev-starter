#!/usr/bin/env bash
# pre-push hook.
# Rejects pushes of branches whose name violates the project convention:
#   <feature|fix|refactor|docs>/#<issue>-<kebab-case-description>
#
# Exempt:
#   - copilot/* / claude/* : agent session-managed branches
#   - main / master / develop : protected branches
#
# Enable with: git config core.hooksPath .githooks
#
# git passes "<local_ref> <local_sha> <remote_ref> <remote_sha>" lines on stdin.

set -euo pipefail

status=0

while read -r _local_ref _local_sha remote_ref _remote_sha; do
  case "$remote_ref" in
    refs/heads/*) branch="${remote_ref#refs/heads/}" ;;
    *) continue ;;  # tags etc.
  esac

  case "$branch" in
    copilot/*|claude/*|main|master|develop)
      continue
      ;;
  esac

  if ! printf '%s' "$branch" | grep -Eq '^(feature|fix|refactor|docs)/#[0-9]+-.+'; then
    cat >&2 <<EOF
[hook:pre-push] Branch name '$branch' violates the project convention.

  Expected: <feature|fix|refactor|docs>/#<issue-number>-<kebab-case-description>
  Example:  feature/#42-add-user-model

  See .github/instructions/git-conventions.instructions.md for details.
  Exempt prefixes: copilot/*, claude/*, main, master, develop.
EOF
    status=1
  fi
done

exit "$status"
